@{
    Layout = "~/Views/Shared/_AgentLayout.cshtml";
    ViewData["Title"] = "Conversations & Messages";
    var staffId = Context.Session.GetInt32("StaffId") ?? 1;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f5f5f5;
        }

        .messaging-container {
            display: flex;
            height: calc(100vh - 100px);
            gap: 1px;
            background: #e0e0e0;
            padding: 20px;
        }

        .conversations-panel {
            width: 300px;
            background: white;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .conversations-header {
            padding: 15px;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .conversations-header h3 {
            font-size: 16px;
            font-weight: 600;
            margin: 0;
        }

        .new-conversation-btn {
            padding: 5px 10px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 12px;
        }

        .conversations-list {
            flex: 1;
            overflow-y: auto;
        }

        .conversation-item {
            padding: 12px 15px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            transition: all 0.2s;
        }

        .conversation-item:hover {
            background: #f9f9f9;
        }

        .conversation-item.active {
            background: #e3f2fd;
            border-left: 3px solid #007bff;
        }

        .conv-title {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 5px;
            color: #000;
        }

        .conv-preview {
            font-size: 12px;
            color: #666;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            margin-bottom: 3px;
        }

        .conv-date {
            font-size: 11px;
            color: #999;
        }

        .conv-badge {
            display: inline-block;
            background: #dc3545;
            color: white;
            border-radius: 10px;
            padding: 2px 6px;
            font-size: 10px;
            margin-left: 5px;
        }

        .messages-panel {
            flex: 1;
            background: white;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .messages-header {
            padding: 20px;
            border-bottom: 1px solid #e0e0e0;
        }

        .messages-header h2 {
            margin: 0 0 5px 0;
            font-size: 18px;
            font-weight: 600;
        }

        .messages-header p {
            margin: 0;
            color: #666;
            font-size: 14px;
        }

        .messages-list {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .message {
            margin-bottom: 15px;
            display: flex;
            gap: 10px;
        }

        .message.own {
            justify-content: flex-end;
        }

        .message-bubble {
            padding: 10px 15px;
            border-radius: 8px;
            max-width: 60%;
        }

        .message.own .message-bubble {
            background: #007bff;
            color: white;
        }

        .message.other .message-bubble {
            background: #f0f0f0;
            color: #000;
        }

        .message-time {
            font-size: 11px;
            color: #999;
            margin-top: 5px;
        }

        .message-input-area {
            padding: 20px;
            border-top: 1px solid #e0e0e0;
            display: flex;
            gap: 10px;
        }

        .message-input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-family: inherit;
            font-size: 14px;
            resize: none;
            max-height: 100px;
        }

        .send-btn {
            padding: 10px 20px;
            background: #007bff;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
        }

        .send-btn:hover {
            background: #0056b3;
        }

        .empty-state {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #999;
            text-align: center;
        }

        .loading {
            text-align: center;
            padding: 20px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="messaging-container">
        <!-- Conversations Panel -->
        <div class="conversations-panel">
            <div class="conversations-header">
                <h3>Conversations</h3>
                <button class="new-conversation-btn" onclick="messagingUI.showNewConversationDialog()">+ New</button>
            </div>
            <div class="conversations-list" id="conversations-list">
                <div class="loading">Loading conversations...</div>
            </div>
        </div>

        <!-- Messages Panel -->
        <div class="messages-panel">
            <div id="messages-panel-content">
                <div class="empty-state">Select a conversation to start messaging</div>
            </div>
        </div>
    </div>

    <script src="~/js/messaging.js" asp-append-version="true"></script>
    <script>
        // Set staff ID globally
        window.currentStaffId = @staffId;
        
        // Override the messaging UI initialization
        let messagingUI;
        document.addEventListener('DOMContentLoaded', () => {
            MESSAGING_API.staffId = window.currentStaffId;
            messagingUI = new MessagingUI();
        });
    </script>
</body>
</html>
